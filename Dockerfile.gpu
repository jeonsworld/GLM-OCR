FROM python:3.12-slim

WORKDIR /app

# System dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        git \
    && rm -rf /var/lib/apt/lists/*

# Clone repository
RUN git clone https://github.com/zai-org/GLM-OCR.git .

# Install package with server (Flask) + selfhosted extras
RUN pip install --no-cache-dir ".[selfhosted,server]"

# Self-hosted GPU mode defaults
ENV GLMOCR_MODE=selfhosted
ENV GLMOCR_ENABLE_LAYOUT=true
ENV GLMOCR_OCR_API_HOST=vllm
ENV GLMOCR_OCR_API_PORT=8000

EXPOSE 8511

ENTRYPOINT ["python", "-m", "glmocr.server"]
